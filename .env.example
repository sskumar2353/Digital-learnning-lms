   # MYSQL_HOST=caboose.proxy.rlwy.net
   # MYSQL_USER=root
   # MYSQL_PASSWORD=xDrjPUqarmAoIJjyoYJlTSMGgRyZJdpL
   # MYSQL_DATABASE=lms
   # MYSQL_PORT=39708

   # VITE_API_URL=http://localhost:3001
   # VITE_AI_API_URL=http://localhost:8000

   MYSQL_HOST=localhost
   MYSQL_USER=root
   MYSQL_PASSWORD=pass123
   MYSQL_DATABASE=lms
   MYSQL_PORT=3306
   # AWS RDS: enable TLS (optional; also auto-enabled when host contains rds.amazonaws.com)
   # MYSQL_SSL=1
   # MYSQL_SSL_REJECT_UNAUTHORIZED=0

   # --- Production (Render + S3-compatible object storage for uploads) ---
   # Works with AWS S3 or S3-compatible providers (Cloudflare R2, etc.).
   # Files are still referenced by path in MySQL (e.g. textbook/chapter_1.pdf); binaries live in object storage.
   # S3_BUCKET=your-lms-uploads
   # AWS_REGION=ap-south-1
   # For Cloudflare R2:
   # AWS_REGION=auto
   # S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
   # S3_FORCE_PATH_STYLE=1
   # AWS_ACCESS_KEY_ID=
   # AWS_SECRET_ACCESS_KEY=
   # Public URL of this API (QR codes, links). On Render: https://your-service.onrender.com
   # APP_BASE_URL=https://your-service.onrender.com

   VITE_API_URL=http://localhost:3001

   # Mobile live-quiz QR (phone on another network): point to your tunnel URL so QR opens the API host.
   # Example: ngrok http 3001  →  QR_BASE_URL=https://your-subdomain.ngrok-free.dev
   # QR_BASE_URL=

   # [LIVE_QUIZ_CHECK] console logs: set to 0 to silence server checkpoints (default: on)
   # LIVE_QUIZ_CHECKPOINTS=0
   # VITE_LIVE_QUIZ_CHECKPOINTS=0

   # AI Chatbot: GROQ API key (get one at https://console.groq.com). Do not commit the real key.
   # GROQ_API_KEY=your_groq_api_key_here

   # Optional: external quiz API for "Launch Quiz" (used when local AI on :8000 is not running)
   # QUIZ_API_URL=https://quiz-1-qo31.onrender.com
   # If true, allows synthetic placeholder quiz questions when AI is unavailable.
   # Keep this false in production.
   # ALLOW_PLACEHOLDER_QUIZ=false

   # Teacher Quiz external UI (iframe) base URL
   # VITE_QUIZ_APP_URL=https://quiz-1-qo31.onrender.com