# Copy to .env and fill in. Do not commit .env.

# Chatbot defaults to a broadly supported setup.
# CHATBOT_TASK=text-generation
# CHATBOT_MODEL=distilgpt2
# CHATBOT_FALLBACK_MODEL=distilgpt2

# YouTube Data API v3 key (for recommendations; get from Google Cloud Console)
# YOUTUBE_API_KEY=your_key_here
# Set to true to fail startup when YOUTUBE_API_KEY is missing.
# REQUIRE_YOUTUBE_API=false

# Recommendations timeout (seconds)
# RECO_TIMEOUT_SECONDS=15
